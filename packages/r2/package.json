{
  "name": "@s2js/r2",
  "version": "0.1.0",
  "type": "module",
  "description": "Two-dimensional Cartesian geometry for the S2 Geometry Library",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@s2js/r1": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Rodrigo Sasaki",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodrigopsasaki/s2js.git",
    "directory": "packages/r2"
  },
  "keywords": [
    "s2",
    "geometry",
    "cartesian",
    "r2",
    "point",
    "rect"
  ]
}
